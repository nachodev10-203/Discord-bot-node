{
  "name": "@workspace/discord-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "deploy-commands:built": "node --enable-source-maps ./dist/deploy-commands.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.21.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "tsx": "catalog:",
    "typescript": "~5.9.3"
  }
}
